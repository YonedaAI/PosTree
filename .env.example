# ═══════════════════════════════════════
# RECOMMENDED: Use Postiz (handles all platforms)
# One backend, no individual OAuth needed
# ═══════════════════════════════════════

# Postiz (self-hosted social media scheduler)
# Setup: docker-compose up -d (see README)
POSTIZ_URL=http://localhost:3000
POSTIZ_API_KEY=

# ═══════════════════════════════════════
# ALTERNATIVE: Individual platform keys
# Only needed if NOT using Postiz
# ═══════════════════════════════════════

# LLM Providers (for postree generate)
# Claude: auto-detected via claude CLI
# Gemini: auto-detected via gemini CLI
OPENAI_API_KEY=

# Twitter/X (developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Mastodon (instance settings → Development → New Application)
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# Bluesky (Settings → App Passwords)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# LinkedIn (developer.linkedin.com)
LINKEDIN_ACCESS_TOKEN=

# Dev.to (dev.to/settings/extensions)
DEVTO_API_KEY=

# Medium (medium.com/me/settings → Integration tokens)
MEDIUM_INTEGRATION_TOKEN=
MEDIUM_AUTHOR_ID=

# Facebook Page (developers.facebook.com)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Reddit (reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Discord (Webhook URL from channel settings)
DISCORD_WEBHOOK_URL=

# Discourse (instance admin → API keys)
DISCOURSE_INSTANCE_URL=
DISCOURSE_API_KEY=
DISCOURSE_API_USERNAME=
